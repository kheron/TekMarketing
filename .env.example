# TekMarketing Environment Configuration
# Copy this file to .env.local and fill in your values

# ============================================
# AI PROVIDERS (at least one required)
# ============================================
# Keys can also be set encrypted in Settings UI
XAI_API_KEY=your_xai_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# ============================================
# DATABASE (Prisma + SQLite for local dev)
# ============================================
DATABASE_URL="file:./dev.db"

# ============================================
# ENCRYPTION (for API keys stored in DB)
# ============================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SETTINGS_ENCRYPTION_KEY=your_32_byte_hex_key_here

# ============================================
# OPTIONAL: Inngest (production scheduling)
# ============================================
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=
