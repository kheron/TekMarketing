# TekMarketing Environment Configuration
# Copy this file to .env.local and fill in your values

# ============================================
# AI PROVIDERS (at least one required)
# ============================================
# Keys can also be set encrypted in Settings UI
XAI_API_KEY=your_xai_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# ============================================
# DATABASE
# ============================================
# PostgreSQL (Neon recommended — free tier works for local + production):
DATABASE_URL="postgresql://user:pass@host/tekmarketing?sslmode=require"
# Local SQLite (legacy): switch prisma/schema.prisma provider to sqlite and use file:./dev.db

# ============================================
# ENCRYPTION (for API keys stored in DB)
# ============================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SETTINGS_ENCRYPTION_KEY=your_32_byte_hex_key_here

# ============================================
# OPTIONAL: Inngest (production scheduling)
# ============================================
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=

# ============================================
# TEKHERO COMMERCIAL (business / client deployments)
# ============================================
# Open Core personal use: leave these unset.
# Commercial license: https://github.com/kheron/TekMarketing/blob/main/COMMERCIAL.md
# COMMERCIAL_MODE=true
# TEKHERO_LICENSE_KEY=TKM-XXXX-XXXX-XXXX   # format issued by TEKHERO
# TEKHERO_EDITION=commercial
# TELEMETRY_OPT_IN=false

# Production personal/non-commercial deploy (honor system — blocks agent APIs without this OR license):
# TEKHERO_OPEN_CORE_ACK=true

# Canonical product URL when deployed at tekhero.us/tekmarketing:
# NEXT_PUBLIC_TEKHERO_PRODUCT_URL=https://tekhero.us/tekmarketing
